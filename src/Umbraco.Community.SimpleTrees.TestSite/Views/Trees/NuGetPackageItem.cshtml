@using Umbraco.Community.SimpleTrees.TestSite
@inherits Umbraco.Community.SimpleTrees.Web.SimpleTreeViewPage
@{
	var split = Model.Unique.Split('_');
	var packageId = split[0];
	var version = split.Length > 1 ? split[1] : null;
	var service = new NuGetService();
	var versions = (await service.GetPackageMetadata(packageId)).Reverse().ToList();
	if (versions.Count == 0)
	{
		<uui-box headline="Package not found">
			<div>
				The package with ID <strong>@packageId</strong> was not found.
			</div>
		</uui-box>
		return;
	}

	var package = versions.First();
	if (!version.IsNullOrWhiteSpace())
	{
		return;
	}
}

<uui-box headline="@package.Title">
	<img src="@package.IconUrl" alt="Icon for @package.Title" style="max-width: 100px; max-height: 100px;"/>
	<div>
		@package.Description
	</div>
	<uui-button href="@package.ProjectUrl" target="_blank">
		Project URL
	</uui-button>
	@if (package.ReadmeUrl != null)
	{
		<uui-button href="@package.ReadmeUrl" target="_blank">
			Readme URL
		</uui-button>
	}
	<div>
		@versions.Count versions
	</div>
</uui-box>

